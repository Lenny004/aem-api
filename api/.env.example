# =============================================================================
# AEM API — Variables de entorno
# Copia este archivo como .env y completa los valores vacíos.
# =============================================================================

# --- Aplicación ---
APP_NAME=Laravel
APP_ENV=local
# Generar con: php artisan key:generate
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# --- Logs ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Base de datos (PostgreSQL en Docker) ---
# DB_HOST debe coincidir con el nombre del servicio en docker-compose.yml
DB_CONNECTION=pgsql
DB_HOST=db-postgres
DB_PORT=5432
DB_DATABASE=aem_db
DB_USERNAME=aem_user
# Debe coincidir con POSTGRES_PASSWORD en docker-compose.yml
DB_PASSWORD=

# --- Sesión ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Servicios de Laravel ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Correo (en desarrollo se escribe en el log) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS (opcional, no usado en desarrollo local) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Autenticación JWT (tymon/jwt-auth) ---
# Generar con: php artisan jwt:secret
JWT_SECRET=
